# SyOps 환경변수
SYOPS_SECRET_KEY=your-secret-key-here

# JWT (선택 — 기본값: 30분 / 30일)
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=30

# DB (선택 — 기본값: sqlite+aiosqlite:///./data/syops.db)
# DATABASE_URL=sqlite+aiosqlite:///./data/syops.db

# 서비스 헬스체크 대상 (backend/core/config.py 필드명과 일치)
QUICKDROP_LOCAL_URL=http://127.0.0.1:8200
NEWS_AGENT_ROOT=/var/www/news-agent
